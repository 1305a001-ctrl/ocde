# OCDE — Oracle Confidence Divergence Engine
#
# Run on ai-staging (per the PC redistribution plan); writes to ai-primary
# Redis. Press-button-ready: paste env vars + `docker compose up -d`.

REDIS_URL=redis://:CHANGEME@redis:6379/0

# --- Pyth Hermes ---
PYTH_HERMES_WS_URL=wss://hermes.pyth.network/ws
PYTH_HERMES_HTTP_URL=https://hermes.pyth.network

# Per-asset Pyth feed IDs. Refresh from https://pyth.network/developers/price-feed-ids
# Format: alias:hex_id (no 0x prefix), comma-separated.
PYTH_FEED_IDS_CSV=btc:e62df6c8b4a85fe1a67db44dc12de5db330f7ac66b72dc658afedf0f4a415b43,eth:ff61491a931112ddf1bd8147cd1b641375f79f5825126d665480874634fd0ace,sol:ef0d8b6fda2ceba41da15d4095d1da392a0d2f8ed0c6c7bc0f4cfac8c280b56d,usdc:eaa020c61cc479712813461ce153894a96a6c00b21ed0cfc2798d1f9a9e9c94a

# --- Chainlink (consumes from chainlink-streams) ---
# Aliases must match what chainlink-streams publishes to chainlink:<alias>:latest
CHAINLINK_FEED_ALIASES_CSV=btc,eth,sol,usdc

# --- Composite scoring ---
COMPOSITE_WEIGHT_DIVERGENCE=0.5
COMPOSITE_WEIGHT_CONFIDENCE=0.3
COMPOSITE_WEIGHT_DISPERSION=0.2
COMPOSITE_PUBLISH_THRESHOLD=0.05

# --- Cycle cadence ---
CYCLE_INTERVAL_SEC=1.0
CONFIDENCE_WINDOW_N=60

# --- Output streams ---
SCORE_STREAM_TEMPLATE=ocde:scores:{alias}
SCORE_STREAM_MAXLEN=1000000
SCORE_LATEST_TEMPLATE=ocde:score:{alias}:latest

# --- HTTP ---
HTTP_HOST=0.0.0.0
HTTP_PORT=8014
LOG_LEVEL=INFO
